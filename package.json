{
    "name": "repo-parallelizer",
    "version": "0.3.0",
    "description": "Parallelization of VS Code workspaces with multiple local git repositories",
    "main": "dist/index.js",
    "keywords": [
        "git",
        "repository",
        "workspace",
        "vscode",
        "parallel",
        "clone",
        "branch",
        "cli"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Mistralys/repo-parallelizer.git"
    },
    "files": [
        "dist/cli/",
        "dist/config/",
        "dist/git/",
        "dist/models/",
        "dist/orchestration/",
        "dist/server/*.js",
        "dist/server/*.js.map",
        "dist/server/routes/",
        "dist/storage/",
        "dist/utils/",
        "dist/errors.js",
        "dist/errors.js.map",
        "dist/index.js",
        "dist/index.js.map",
        "gui/public/",
        "config.dist.json",
        "menu.sh",
        "menu.cmd"
    ],
    "engines": {
        "node": ">=18",
        "git": ">=2.28"
    },
    "bin": {
        "paralizer": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "test": "tsc && node --test dist/tests/*.test.js dist/server/__tests__/*.test.js dist/server/__tests__/**/*.test.js",
        "copy-vendor": "node -e \"const fs = require('fs'); fs.mkdirSync('gui/public/css/vendor', { recursive: true }); fs.copyFileSync('node_modules/@picocss/pico/css/pico.classless.min.css', 'gui/public/css/vendor/pico.classless.min.css');\"",
        "postinstall": "npm run copy-vendor"
    },
    "devDependencies": {
        "@picocss/pico": "^2.1.1",
        "@types/node": "^25.5.1",
        "jsdom": "^29.0.2",
        "typescript": "^5.4.0"
    },
    "dependencies": {
        "picocolors": "^1.1.1"
    }
}
